import os
import sys
import oracledb
import git
import datetime
from uuid import uuid4
import json
import argparse
import time
import warnings
import socket
import threading

warnings.filterwarnings("ignore", category=ResourceWarning)

try:
    import tomllib
except ImportError:
    import tomli as tomllib

CONFIG_FILE = "config.toml"


def load_config():
    if not os.path.exists(CONFIG_FILE):
        return {}
    with open(CONFIG_FILE, "rb") as f:
        return tomllib.load(f)


def get_db_credentials(config):
    db_user = os.environ.get('DB_USER')
    db_pass = os.environ.get('DB_PASS')
    dsn = os.environ.get('DB_DSN')

    if not db_user:
        db_user = config.get("database", {}).get("db_user")
    if not db_pass:
        db_pass = config.get("database", {}).get("db_password")
    if not dsn:
        dsn = config.get("database", {}).get("default_dsn")

    if not db_user or not db_pass or not dsn:
        print("Ошибка: не найдены DB_USER, DB_PASS или DB_DSN")
        sys.exit(1)

    print("Логин/пароль/DSN к БД взяты из Jenkins или config.toml")
    return db_user, db_pass, dsn


def checkout_and_pull_branch(repo, branch_name):
    git_user = os.environ.get('GIT_USER')
    git_pass = os.environ.get('GIT_PASS')

    if not git_user or not git_pass:
        print("Ошибка: GIT_USER или GIT_PASS не установлены")
        sys.exit(1)

    auth_url = f"https://{git_user}:{git_pass}@git.moscow.alfaintra.net/scm/bialm_ft/bialm_ft_auto.git"
    repo.remotes.origin.config_writer.set("url", auth_url)

    try:
        repo.remotes.origin.fetch()
        repo.git.checkout(branch_name)
        repo.git.pull('origin', branch_name)
    except git.exc.GitCommandError as e:
        print(f"Ошибка git: {e}")
        sys.exit(1)


def run_sql_file(sql_path, db_user, db_pass, dsn):
    file_name = os.path.basename(sql_path)
    status = "passed"
    message = "OK — дубликатов не найдено"
    details = ""

    start_time = int(time.time() * 1000)

    try:
        conn = oracledb.connect(user=db_user, password=db_pass, dsn=dsn)
        cursor = conn.cursor()
        sql = open(sql_path, 'r', encoding='utf-8').read().rstrip(' \n;')
        cursor.execute(sql)
        rows = cursor.fetchall()

        if rows:
            status = "failed"
            message = f"Найдено {len(rows)} наборов дубликатов"
            details = "\n".join(str(row) for row in rows)

        conn.close()

    except oracledb.Error as e:
        status = "broken"
        message = "Ошибка выполнения"
        details = str(e)

    stop_time = int(time.time() * 1000)

    return status, message, details, file_name, start_time, stop_time


def create_allure_results(results, branch_name):
    allure_dir = "allure-results"
    os.makedirs(allure_dir, exist_ok=True)

    for r in results:
        test_uuid = str(uuid4())
        container_uuid = str(uuid4())

        attachments = []

        if r["details"]:
            attach_filename = f"{test_uuid}-details.txt"
            attach_path = os.path.join(allure_dir, attach_filename)
            with open(attach_path, 'w', encoding='utf-8') as f:
                f.write(r["details"])

            attachments.append({
                "name": "Details",
                "source": attach_filename,
                "type": "text/plain"
            })

        status_map = {
            "passed": "passed",
            "failed": "failed",
            "broken": "broken"
        }

        # ---------- RESULT ----------
        result_data = {
            "uuid": test_uuid,
            "historyId": r["file"],  # стабильная история по имени файла
            "name": r["file"],
            "fullName": f"Duplicate Check: {r['file']}",
            "status": status_map.get(r["status"], "broken"),
            "stage": "finished",
            "description": r["message"],
            "start": r["start"],
            "stop": r["stop"],
            "steps": [
                {
                    "name": "Execute SQL",
                    "status": status_map.get(r["status"], "broken"),
                    "stage": "finished",
                    "start": r["start"],
                    "stop": r["stop"]
                }
            ],
            "attachments": attachments,
            "labels": [
                {"name": "framework", "value": "custom-sql"},
                {"name": "language", "value": "python"},
                {"name": "suite", "value": "SQL Duplicate Checks"},
                {"name": "host", "value": socket.gethostname()},
                {"name": "thread", "value": threading.current_thread().name},
                {"name": "branch", "value": branch_name}
            ]
        }

        with open(os.path.join(allure_dir, f"{test_uuid}-result.json"), 'w', encoding='utf-8') as f:
            json.dump(result_data, f, ensure_ascii=False)

        # ---------- CONTAINER ----------
        container_data = {
            "uuid": container_uuid,
            "children": [test_uuid],
            "befores": [],
            "afters": [],
            "start": r["start"],
            "stop": r["stop"]
        }

        with open(os.path.join(allure_dir, f"{container_uuid}-container.json"), 'w', encoding='utf-8') as f:
            json.dump(container_data, f, ensure_ascii=False)

    print("Allure results generated correctly for TestOps.")


def main():
    parser = argparse.ArgumentParser(description="Запуск проверки дубликатов")
    parser.add_argument('--branch', required=True)
    args = parser.parse_args()

    config = load_config()
    repo_path = "."

    if not os.path.exists(os.path.join(repo_path, ".git")):
        print("Репозиторий не найден")
        sys.exit(1)

    repo = git.Repo(repo_path)
    checkout_and_pull_branch(repo, args.branch)

    tests_dir = os.path.join(repo_path, config["tests"]["tests_directory"])
    sql_files = [f for f in os.listdir(tests_dir) if f.endswith('.sql')]

    if not sql_files:
        print("SQL-файлы не найдены")
        sys.exit(1)

    db_user, db_pass, dsn = get_db_credentials(config)

    results = []

    print("\nВыполняю проверки...")
    for sql_file in sql_files:
        sql_path = os.path.join(tests_dir, sql_file)
        print(f"→ {sql_file}")
        status, message, details, fname, start, stop = run_sql_file(sql_path, db_user, db_pass, dsn)

        results.append({
            "status": status,
            "message": message,
            "details": details,
            "file": fname,
            "start": start,
            "stop": stop
        })

    create_allure_results(results, args.branch)

    print("\nГотово! Папка allure-results создана.")


if __name__ == "__main__":
    main()
