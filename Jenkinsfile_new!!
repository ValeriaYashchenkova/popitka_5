pipeline {
    agent {
        kubernetes {
            inheritFrom 'python'
            defaultContainer 'python-builder'
        }
    }

    triggers {
        pollSCM('')
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '20'))
        timeout(time: 60, unit: 'MINUTES')
    }

    parameters {
        string(
            name: 'BRANCH_NAME',
            defaultValue: 'master',
            description: 'Ветка для запуска тестов'
        )
        string(
            name: 'DB_USER',
            defaultValue: '',
            description: 'Логин для подключения к Oracle DB'
        )
        password(
            name: 'DB_PASS',
            defaultValue: '',
            description: 'Пароль для подключения к Oracle DB'
        )
    }

    environment {
        PATH = "/var/lib/jenkins/.local/bin:$PATH"
        ALLURE_RESULTS = "${WORKSPACE}/allure-results"
    }

    stages {
        stage('Prepare & Install dependencies') {
            steps {
                sh '''
                    python3 -m venv venv || true
                    . venv/bin/activate
                    pip install --upgrade pip setuptools wheel \
                        -i https://binary.alfabank.ru/artifactory/api/pypi/pipy-virtual/simple
                    
                    pip install oracledb pytest allure-pytest \
                        -i https://binary.alfabank.ru/artifactory/api/pypi/pipy-virtual/simple
                '''
            }
        }

        stage('Run tests') {
            steps {
                sh '''
                    . venv/bin/activate
                    
                    echo "Current directory:"
                    pwd
                    
                    echo "Files in tests/:"
                    ls -la tests/ || echo "Папка tests/ не найдена"
                    
                    rm -rf "${ALLURE_RESULTS}" || true
                    mkdir -p "${ALLURE_RESULTS}"
                    
                    export DB_USER="${params.DB_USER}"
                    export DB_PASS="${params.DB_PASS}"
                    
                    pytest tests/ \
                        --alluredir="${ALLURE_RESULTS}" \
                        || echo "Тесты завершились с ошибкой, но отчёт будет опубликован"
                '''
            }
        }
    }

    post {
        always {
            allure(
                includeProperties: false,
                jdk: '',
                results: [[path: 'allure-results']]
            )

            script {
                try {
                    echo "Uploading results to Allure TestOps..."
                    withAllureUpload(
                        credentialsId: 'allure-token',
                        name: "DB Tests #${BUILD_NUMBER} | ${params.BRANCH_NAME}",
                        projectId: '643',
                        results: [[path: "${ALLURE_RESULTS}"]],
                        serverId: 'testops',
                        tags: "${params.BRANCH_NAME}, oracle, data-quality"
                    ) {
                        echo "Allure TestOps upload completed"
                    }
                } catch (Exception e) {
                    echo "Не удалось загрузить в Allure TestOps: ${e.message}"
                }
            }

            archiveArtifacts(
                artifacts: 'allure-results/**',
                allowEmptyArchive: true,
                fingerprint: true
            )

            cleanWs()
        }
    }
}
