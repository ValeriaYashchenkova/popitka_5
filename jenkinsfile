pipeline {
agent {
kubernetes {
inheritFrom 'python'
defaultContainer 'python-builder'
}
}
triggers {
pollSCM('')
}
options {
buildDiscarder(logRotator(numToKeepStr: '20'))
}
parameters {
string(
name: 'BRANCH_NAME',
defaultValue: 'master',
description: 'Ветка для проверки дубликатов (например feature/duplicates-test)'
)
string(
name: 'DB_USER',
defaultValue: '',
description: 'Логин для подключения к Oracle DB'
)
password(
name: 'DB_PASS',
defaultValue: '',
description: 'Пароль для подключения к Oracle DB'
)
string(
name: 'GIT_USER',
defaultValue: '',
description: 'Логин для Bitbucket'
)
password(
name: 'GIT_PASS',
defaultValue: '',
description: 'Пароль для Bitbucket'
)
}
environment {
PATH = "/var/lib/jenkins/.local/bin:$PATH"
ALLURE_RESULTS = "allure-results"
}
stages {
stage('Checkout SCM') {
steps {
checkout([
$class: 'GitSCM',
branches: [[name: "${params.BRANCH_NAME}"]],
userRemoteConfigs: [[
url: 'https://git.moscow.alfaintra.net/scm/bialm_ft/bialm_ft_auto.git',
credentialsId: 'git_pass'
]]
])
}
}
stage('Create venv & Install dependencies') {
steps {
sh """
python3.7 -m venv venv || true
. venv/bin/activate
pip3.7 install --upgrade pip -i https://binary.alfabank.ru/artifactory/api/pypi/pipy-virtual/simple
pip3.7 install oracledb gitpython requests tomli -i https://binary.alfabank.ru/artifactory/api/pypi/pipy-virtual/simple
"""
}
}
stage('Run Duplicate Checks') {
steps {
sh """
. venv/bin/activate
rm -rf ${ALLURE_RESULTS}
mkdir -p ${ALLURE_RESULTS}
export DB_USER="${params.DB_USER}"
export DB_PASS="${params.DB_PASS}"
export GIT_USER="${params.GIT_USER}"
export GIT_PASS="${params.GIT_PASS}"
python run_test.py --branch ${BRANCH_NAME}
"""
}
}
}
post {
always {
script {
allure([
includeProperties: false,
jdk: '',
properties: [],
reportBuildPolicy: 'ALWAYS',
results: [[path: 'allure-results']]
])
allureTestOpsUpload(
allureResultsPath: 'allure-results',
endpoint: 'https://testops.moscow.alfaintra.net',
projectId: '643'
)
}
archiveArtifacts artifacts: 'allure-results/**', allowEmptyArchive: true
cleanWs()
}
}
}
